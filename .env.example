# .env.example -- Required environment variables for the docker-compose demo
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Generate SECRET_KEY_BASE with:
#   mix phx.gen.secret

# Phoenix secret key base (required, minimum 64 bytes)
SECRET_KEY_BASE=

# External Postgres (Option B — you already have PG running):
# Set this to point at your existing instance.
# With Option A (--profile db), leave commented and the managed container is used.
# DATABASE_URL=ecto://postgres:postgres@host.docker.internal/lemmings_os_dev

# Managed Postgres credentials (Option A -- docker compose --profile db up)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=lemmings_os_prod

# Phoenix host for URL generation (default: localhost)
# PHX_HOST=localhost

# Host port to expose the world web UI (default: 4000)
# PHX_PORT=4000

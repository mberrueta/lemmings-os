export MIX_PORT="${MIX_PORT:-4000}"
export TIDEWAVE_PORT="${TIDEWAVE_PORT:-4001}"
export LIVE_DEBUGGER_PORT="${LIVE_DEBUGGER_PORT:-4002}"
export TEST_PORT="${TEST_PORT:-${LIVE_DEBUGGER_PORT}}"
export PORT="${PORT:-${MIX_PORT}}"

export OLLAMA_BASE_URL=http://localhost:11434

# Source-file embeddings default to Ollama via OpenAI-compatible /v1 endpoint.
# Pull once: `ollama pull nomic-embed-text`
export LEMMINGS_KNOWLEDGE_EMBEDDING_PROVIDER="openai_compatible"
export LEMMINGS_KNOWLEDGE_EMBEDDING_BASE_URL="http://127.0.0.1:11434/v1"
export LEMMINGS_KNOWLEDGE_EMBEDDING_MODEL="nomic-embed-text"
export LEMMINGS_KNOWLEDGE_EMBEDDING_DIMENSIONS="1536"
# Required by current embedder path; Ollama ignores the token value.
export OPENAI_API_KEY="dummy"

export LEMMINGS_WORK_AREAS_PATH="~/.lemmings/workspace"
export LEMMINGS_ARTIFACT_STORAGE_ROOT="~/.lemmings/storage"
export LEMMINGS_KNOWLEDGE_SOURCE_FILE_STORAGE_ROOT="~/.lemmings/knowledge"

export LEMMINGS_GOTENBERG_URL="http://127.0.0.1:3000"

[ -f .envrc.custom ] && source .envrc.custom
